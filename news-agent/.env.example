# ═══════════════════════════════════════════════════════════════════════════
# NEWS INTELLIGENCE AGENT — ZERO API KEYS REQUIRED
# Everything works out of the box. API keys are 100% optional upgrades.
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM (OPTIONAL — improves summaries, not required) ───────────────────
# Google Gemini (free): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (paid, fallback): https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Extra News Source (OPTIONAL) ─────────────────────────────────────────
# NewsAPI (free tier): https://newsapi.org/register
NEWS_API_KEY=

# ── Telegram Alerts (OPTIONAL) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Daily Email Digest (OPTIONAL) ───────────────────────────────────────
# Sends a beautiful HTML email every morning with top stories.
# For Gmail: use an App Password (NOT your regular password).
# Steps: Google Account → Security → 2-Step Verification → App Passwords
# Create one for "Mail" → copy the 16-char password here.
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=your.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=your.email@gmail.com
EMAIL_DIGEST_HOUR=8
EMAIL_DIGEST_MINUTE=30

# ── Filters ──────────────────────────────────────────────────────────────
PRIORITY_KEYWORDS=AI,funding,layoffs,startup,IPO,acquisition,regulation,open source,GPT,LLM
FILTER_KEYWORDS=
MIN_PRIORITY_SCORE=40

# ── Polling ──────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=120

# ── Dashboard ────────────────────────────────────────────────────────────
DASHBOARD_MAX_ARTICLES=30

# ── Database ─────────────────────────────────────────────────────────────
DB_PATH=news.db
MAX_ARTICLE_AGE_HOURS=48

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
