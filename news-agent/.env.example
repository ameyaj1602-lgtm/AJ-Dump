# ── LLM — Google Gemini (FREE forever) ──────────────────────────────────────
# Get your free key: https://aistudio.google.com/apikey
# Free tier: 15 requests/min, 1 million tokens/day — more than enough
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── LLM — OpenAI (optional, paid — only used if Gemini key is empty) ────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── News Sources ─────────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register (optional, RSS works alone)
NEWS_API_KEY=

# ── Telegram Alerts (FREE) ──────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Filters ──────────────────────────────────────────────────────────────────
# Keywords that BOOST priority score (+10)
PRIORITY_KEYWORDS=AI,funding,layoffs,startup,IPO,acquisition,regulation,open source,GPT,LLM

# If set, ONLY articles matching these keywords are forwarded (comma-separated).
# Leave empty to receive all news.
FILTER_KEYWORDS=

# Minimum priority score (0-100) to trigger an alert
MIN_PRIORITY_SCORE=30

# ── Polling ──────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=120

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=news.db

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
