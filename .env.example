# ============================================
# Therapy Voice Agent Configuration
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================

# --- OpenAI (REQUIRED) — The Brain ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- ElevenLabs (REQUIRED) — The Voice ---
# Sign up free at: https://elevenlabs.io
# Get your key at: https://elevenlabs.io/app/settings/api-keys
ELEVEN_API_KEY=your-elevenlabs-key-here

# --- Deepgram (REQUIRED) — The Ears ---
# Sign up free at: https://console.deepgram.com (free $200 credit!)
# Get your key at: https://console.deepgram.com/project/settings/api-keys
DEEPGRAM_API_KEY=your-deepgram-key-here

# --- LiveKit (REQUIRED) — The Orchestrator ---
# Sign up free at: https://cloud.livekit.io
# Go to Settings > Keys to find these
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
